{
  "$schema": "./workflow.schema.json",
  "name": "hello-world",
  "nodes": [
    {
      "id": "node_1",
      "type": "run",
      "position": {
        "x": 100,
        "y": 100
      },
      "config": {
        "command": "echo 'Hello from GitHub Actions!' && date -u"
      }
    },
    {
      "id": "node_2",
      "type": "http",
      "position": {
        "x": 100,
        "y": 250
      },
      "config": {
        "method": "GET",
        "url": "https://api.github.com/zen"
      }
    },
    {
      "id": "node_3",
      "type": "delay",
      "position": {
        "x": 100,
        "y": 400
      },
      "config": {
        "ms": 1000
      }
    },
    {
      "id": "node_4",
      "type": "notify",
      "position": {
        "x": 100,
        "y": 550
      },
      "inputs": {
        "zen_phrase": "{{ nodes.node_2.outputs.response }}",
        "timestamp": "{{ nodes.node_1.outputs.output }}"
      },
      "config": {
        "message": "hello-world workflow reached its final step!\n\nZen quote: {{ nodes.node_2.outputs.response }}\nLast run output:\n{{ nodes.node_1.outputs.output }}"
      }
    }
  ],
  "edges": [
    {
      "source": "node_1",
      "target": "node_2",
      "sourceHandle": "success"
    },
    {
      "source": "node_2",
      "target": "node_3",
      "sourceHandle": "success"
    },
    {
      "source": "node_3",
      "target": "node_4",
      "sourceHandle": "success"
    }
  ]
}