{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow",
  "description": "A graph-based workflow definition executed by scripts/executor.js on GitHub Actions.",
  "type": "object",
  "required": ["name", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Used to name the execution log file — keep it filesystem-safe."
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["id", "type", "position", "config"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Unique identifier for the node"
          },
          "type": {
            "type": "string",
            "enum": [
              "run",
              "http",
              "delay",
              "notify",
              "webhook_trigger",
              "cron_trigger",
              "telegram_event_trigger"
            ]
          },
          "position": {
            "type": "object",
            "required": ["x", "y"],
            "additionalProperties": false,
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          },
          "config": {
            "type": "object",
            "description": "Configuration specific to the node type"
          },
          "inputs": {
            "type": "object",
            "description": "Inputs to the node, potentially referencing outputs of other nodes"
          },
          "outputs": {
            "type": "object",
            "description": "Declared schema/defaults for outputs of the node"
          }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "run" } } },
            "then": {
              "properties": {
                "config": {
                  "type": "object",
                  "required": ["command"],
                  "additionalProperties": false,
                  "properties": {
                    "command": { "type": "string" },
                    "timeout_ms": { "type": "integer", "minimum": 1 },
                    "continue_on_error": { "type": "boolean" }
                  }
                }
              }
            }
          },
          {
            "if": { "properties": { "type": { "const": "http" } } },
            "then": {
              "properties": {
                "config": {
                  "type": "object",
                  "required": ["url"],
                  "additionalProperties": false,
                  "properties": {
                    "method": { "type": "string" },
                    "url": { "type": "string", "format": "uri" },
                    "headers": { "type": "object" },
                    "body": {},
                    "timeout_ms": { "type": "integer", "minimum": 1 },
                    "continue_on_error": { "type": "boolean" }
                  }
                }
              }
            }
          },
          {
            "if": { "properties": { "type": { "const": "delay" } } },
            "then": {
              "properties": {
                "config": {
                  "type": "object",
                  "required": ["ms"],
                  "additionalProperties": false,
                  "properties": {
                    "ms": { "type": "integer", "minimum": 0, "maximum": 300000 },
                    "continue_on_error": { "type": "boolean" }
                  }
                }
              }
            }
          },
          {
            "if": { "properties": { "type": { "const": "notify" } } },
            "then": {
              "properties": {
                "config": {
                  "type": "object",
                  "required": ["message"],
                  "additionalProperties": false,
                  "properties": {
                    "message": { "type": "string" },
                    "continue_on_error": { "type": "boolean" }
                  }
                }
              }
            }
          },
          {
            "if": { "properties": { "type": { "const": "webhook_trigger" } } },
            "then": {
              "properties": {
                "config": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "secret": { "type": "string" }
                  }
                }
              }
            }
          },
          {
            "if": { "properties": { "type": { "const": "cron_trigger" } } },
            "then": {
              "properties": {
                "config": {
                  "type": "object",
                  "required": ["cron"],
                  "additionalProperties": false,
                  "properties": {
                    "cron": { "type": "string" }
                  }
                }
              }
            }
          },
          {
            "if": { "properties": { "type": { "const": "telegram_event_trigger" } } },
            "then": {
              "properties": {
                "config": {
                  "type": "object",
                  "required": ["event_type"],
                  "additionalProperties": false,
                  "properties": {
                    "event_type": { "type": "string" }
                  }
                }
              }
            }
          }
        ]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "additionalProperties": false,
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "sourceHandle": {
            "type": "string",
            "enum": ["success", "failure", "always"],
            "description": "Indicates on what condition to follow this edge: when the source succeeds, fails, or always. Defaults to success."
          }
        }
      }
    }
  }
}
