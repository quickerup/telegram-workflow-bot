{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow",
  "description": "A workflow definition executed by scripts/executor.js on GitHub Actions.",
  "type": "object",
  "required": ["name", "steps"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Used to name the execution log file — keep it filesystem-safe."
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "command"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "run" },
              "command": { "type": "string", "description": "Shell command, executed via bash on the runner. This is arbitrary code execution — treat it accordingly." },
              "timeout_ms": { "type": "integer", "minimum": 1 },
              "continue_on_error": { "type": "boolean" }
            }
          },
          {
            "type": "object",
            "required": ["type", "url"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "http" },
              "method": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "headers": { "type": "object" },
              "body": {},
              "timeout_ms": { "type": "integer", "minimum": 1 },
              "continue_on_error": { "type": "boolean" }
            }
          },
          {
            "type": "object",
            "required": ["type", "ms"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "delay" },
              "ms": { "type": "integer", "minimum": 0, "maximum": 300000 },
              "continue_on_error": { "type": "boolean" }
            }
          },
          {
            "type": "object",
            "required": ["type", "message"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "notify" },
              "message": { "type": "string" },
              "continue_on_error": { "type": "boolean" }
            }
          }
        ]
      }
    }
  }
}
